local VERSION = "2.0.0"
local SCRIPT_URL = "https://raw.githubusercontent.com/seu_usuario/seu_repo/main/camera_hub.lua" -- COLOQUE SUA URL AQUI!
local GITHUB_RAW_URL = "https://raw.githubusercontent.com/seu_usuario/seu_repo/main/version.txt" -- URL para arquivo de vers√£o

local function checkForUpdates()
    local success, result = pcall(function()
        return game:HttpGet(GITHUB_RAW_URL)
    end)
    
    if success and result then
        local latestVersion = result:match("VERSION=(%d+%.%d+%.%d+)")
        if latestVersion and latestVersion ~= VERSION then
            return true, latestVersion
        end
    end
    return false, VERSION
end

local function updateScript()
    local success, newScript = pcall(function()
        return game:HttpGet(SCRIPT_URL)
    end)
    
    if success and newScript then
        return true, newScript
    end
    return false, nil
end

