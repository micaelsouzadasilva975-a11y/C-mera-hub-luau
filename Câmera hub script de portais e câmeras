    for i = 1, 5 do
        local linha = Instance.new("Part")
        linha.Size = Vector3.new(0.81, 0.1, 1.2)
        linha.Material = Enum.Material.SmoothPlastic
        linha.Color = Color3.fromRGB(45, 45, 45)
        linha.Anchored = true
