local function teleportarJogador(dePortal, paraPortal)
    if not player.Character or not player.Character:FindFirstChild("HumanoidRootPart") then return end
    local playerName = player.Name
    if teleportCooldown[playerName] then return end
    teleportCooldown[playerName] = true
    
    local novaPosicao
    if ladoAparicao == "Frente" then
        novaPosicao = paraPortal.CFrame * CFrame.new(0, 0, -distanciaAparicao)
    elseif ladoAparicao == "Tr√°s" then
        novaPosicao = paraPortal.CFrame * CFrame.new(0, 0, distanciaAparicao)
    elseif ladoAparicao == "Esquerda" then
        novaPosicao = paraPortal.CFrame * CFrame.new(-distanciaAparicao, 0, 0)
    elseif ladoAparicao == "Direita" then
        novaPosicao = paraPortal.CFrame * CFrame.new(distanciaAparicao, 0, 0)
    elseif ladoAparicao == "Cima" then
        novaPosicao = paraPortal.CFrame * CFrame.new(0, distanciaAparicao, 0)
    elseif ladoAparicao == "Baixo" then
        novaPosicao = paraPortal.CFrame * CFrame.new(0, -distanciaAparicao, 0)
    end
    
    player.Character:SetPrimaryPartCFrame(novaPosicao)
    task.wait(tempoTeleporteCooldown)
    teleportCooldown[playerName] = nil
end

local function criarPortal(posicao, olhandoPara)
    if not player.Character then return end
    local numeroPortal = obterProximoNumero()
    local numeroPar = (numeroPortal % 2 == 1) and numeroPortal + 1 or numeroPortal - 1
    local indicePar = math.ceil(numeroPortal / 2)
    
    if not paresPortais[indicePar] then
        local cor1, cor2 = gerarCores()
        paresPortais[indicePar] = {cor1 = cor1, cor2 = cor2}
    end
    
    local cor = (numeroPortal % 2 == 1) and paresPortais[indicePar].cor1 or paresPortais[indicePar].cor2
    local portal = Instance.new("Part")
    portal.Name = "Portal_" .. numeroPortal
    portal.Anchored = true
    portal.CanCollide = false
    portal.Material = Enum.Material.Neon
    portal.Color = cor
    portal.Transparency = transparenciaPortal
    
    local cframe = CFrame.new(posicao, posicao + olhandoPara) * CFrame.Angles(0, math.rad(rotacaoPortal), 0)
    
    if formatoPortal == "Cilindro" then
        portal.Shape = Enum.PartType.Cylinder
        portal.Size = Vector3.new(0.5, tamanhoPortal, tamanhoPortal)
        portal.CFrame = cframe * CFrame.Angles(0, math.rad(90), 0)
    elseif formatoPortal == "Esfera" then
        portal.Shape = Enum.PartType.Ball
        portal.Size = Vector3.new(tamanhoPortal, tamanhoPortal, tamanhoPortal)
        portal.CFrame = cframe
    elseif formatoPortal == "Ret√Ęngulo" then
        portal.Shape = Enum.PartType.Block
        portal.Size = Vector3.new(0.5, tamanhoPortal * 1.3, tamanhoPortal * 0.8)
        portal.CFrame = cframe
    elseif formatoPortal == "Quadrado" then
        portal.Shape = Enum.PartType.Block
        portal.Size = Vector3.new(0.5, tamanhoPortal, tamanhoPortal)
        portal.CFrame = cframe
    elseif formatoPortal == "Tri√Ęngulo" then
        portal.Shape = Enum.PartType.Block
        portal.Size = Vector3.new(0.5, tamanhoPortal, tamanhoPortal)
        portal.CFrame = cframe
        local wedge1 = Instance.new("WedgePart")
        wedge1.Size = Vector3.new(0.5, tamanhoPortal * 0.5, tamanhoPortal)
        wedge1.Material = Enum.Material.Neon
        wedge1.Color = cor
        wedge1.Transparency = transparenciaPortal
        wedge1.Anchored = true
        wedge1.CanCollide = false
        wedge1.CFrame = portal.CFrame * CFrame.new(0, tamanhoPortal * 0.25, 0) * CFrame.Angles(0, 0, math.rad(180))
        wedge1.Parent = portal
    end
    
    portal.Parent = workspace
    
    local billboard = Instance.new("BillboardGui")
    billboard.Size = UDim2.new(0, 100, 0, 100)
    billboard.Adornee = portal
    billboard.AlwaysOnTop = true
    billboard.Parent = portal
    
    local textoNumero = Instance.new("TextLabel")
    textoNumero.Size = UDim2.new(1, 0, 1, 0)
    textoNumero.BackgroundTransparency = 1
    textoNumero.Text = tostring(numeroPortal)
    textoNumero.Font = Enum.Font.GothamBold
    textoNumero.TextSize = 70
    textoNumero.TextColor3 = Color3.new(1, 1, 1)
    textoNumero.TextStrokeTransparency = 0
    textoNumero.TextStrokeColor3 = Color3.new(0, 0, 0)
    textoNumero.Parent = billboard
    
    local function criarZona(offsetZ)
        local zona = Instance.new("Part")
        zona.Name = "Zona_" .. numeroPortal
        zona.Size = Vector3.new(tamanhoPortal + 1, tamanhoPortal + 3, 2)
        zona.Transparency = 1
        zona.CanCollide = false
        zona.Anchored = true
        zona.CFrame = portal.CFrame * CFrame.new(0, 0, offsetZ)
        zona.Parent = portal
        zona.Touched:Connect(function(hit)
            if hit.Parent and hit.Parent:FindFirstChild("Humanoid") then
                if hit.Parent.Name == player.Name then
                    local portalDestino = portaisAtivos[numeroPar]
                    if portalDestino then teleportarJogador(portal, portalDestino) end
                end
            end
        end)
    end
    
    criarZona(3)
    criarZona(-3)
    portaisAtivos[numeroPortal] = portal
    Rayfield:Notify({Title = "Portal #" .. numeroPortal .. " Criado", Content = "Teleporta para Portal #" .. numeroPar, Duration = 2})
end

local function processarNumeros(texto)
    local numeros = {}
    for parte in string.gmatch(texto, "[^,]+") do
        parte = parte:match("^%s*(.-)%s*$")
        if string.find(parte, "-") then
            local inicio, fim = string.match(parte, "(%d+)%-(%d+)")
            if inicio and fim then
                inicio, fim = tonumber(inicio), tonumber(fim)
                for i = inicio, fim do table.insert(numeros, i) end
            end
        else
            local num = tonumber(parte)
            if num then table.insert(numeros, num) end
        end
    end
    return numeros
end

local function atualizarAlturaPortaisSelecionados(novaAltura)
    for _, numero in ipairs(portaisSelecionados) do
        local portal = portaisAtivos[numero]
        if portal and portal.Parent then
            local posicaoAtual = portal.Position
            portal.Position = Vector3.new(posicaoAtual.X, posicaoAtual.Y + novaAltura, posicaoAtual.Z)
        end
    end
end

local function atualizarTamanhoPortaisSelecionados(novoTamanho)
    for _, numero in ipairs(portaisSelecionados) do
        local portal = portaisAtivos[numero]
        if portal and portal.Parent then
            if portal.Shape == Enum.PartType.Cylinder then
                portal.Size = Vector3.new(0.5, novoTamanho, novoTamanho)
            elseif portal.Shape == Enum.PartType.Ball then
                portal.Size = Vector3.new(novoTamanho, novoTamanho, novoTamanho)
            elseif portal.Shape == Enum.PartType.Block then
                if portal.Size.Y > portal.Size.Z then
                    portal.Size = Vector3.new(0.5, novoTamanho * 1.3, novoTamanho * 0.8)
                else
                    portal.Size = Vector3.new(0.5, novoTamanho, novoTamanho)
                end
            end
            for _, child in ipairs(portal:GetChildren()) do
                if child:IsA("WedgePart") then
                    child.Size = Vector3.new(0.5, novoTamanho * 0.5, novoTamanho)
                    child.CFrame = portal.CFrame * CFrame.new(0, novoTamanho * 0.25, 0) * CFrame.Angles(0, 0, math.rad(180))
                end
            end
            for _, child in ipairs(portal:GetChildren()) do
                if child.Name:match("Zona_") then
                    child.Size = Vector3.new(novoTamanho + 1, novoTamanho + 3, 2)
                end
            end
        end
    end
end

local function atualizarTransparenciaPortaisSelecionados(novaTransparencia)
    for _, numero in ipairs(portaisSelecionados) do
        local portal = portaisAtivos[numero]
        if portal and portal.Parent then
            portal.Transparency = novaTransparencia
            for _, child in ipairs(portal:GetChildren()) do
                if child:IsA("WedgePart") then child.Transparency = novaTransparencia end
            end
        end
    end
end

local function atualizarRotacaoPortaisSelecionados(novaRotacao)
    for _, numero in ipairs(portaisSelecionados) do
        local portal = portaisAtivos[numero]
        if portal and portal.Parent then
            local posicaoAtual = portal.Position
            local novoCFrame = CFrame.new(posicaoAtual) * CFrame.Angles(0, math.rad(novaRotacao), 0)
            if portal.Shape == Enum.PartType.Cylinder then
                portal.CFrame = novoCFrame * CFrame.Angles(0, math.rad(90), 0)
            else
                portal.CFrame = novoCFrame
            end
            for _, child in ipairs(portal:GetChildren()) do
                if child.Name:match("Zona_") then
                    local offset = child.CFrame.Z > portal.CFrame.Z and 3 or -3
                    child.CFrame = portal.CFrame * CFrame.new(0, 0, offset)
                end
            end
        end
    end
end

